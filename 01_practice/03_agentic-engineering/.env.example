# ─────────────────────────────────────────────────────────────
# Environment variables for 03_agentic-engineering
#
# Copy this file to `.env` and fill in your real values.
#   cp .env.example .env
#
# `.env` is git-ignored, so your secrets are never committed.
# The API key lives only on the server — it is never sent to the browser.
# ─────────────────────────────────────────────────────────────

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model used for summarization (override if you prefer another)
OPENAI_MODEL=gpt-4o

# App runtime config
PORT=3000
NODE_ENV=development
